# Atlas Clean - Local First Control Panel
# Copy this to .env.local and fill in values

# Required: Secret token for API authentication (keep this local!)
ATLAS_SECRET_TOKEN=generate-a-strong-random-token-here

# Optional: OpenClaw gateway address (default local)
NEXT_PUBLIC_OPENCLaw_GATEWAY=http://localhost:3333

# Port for this dashboard (default 3050)
PORT=3050
