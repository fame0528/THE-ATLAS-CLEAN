# Atlas local configuration
# Copy to .env.local and fill in values

# Required: Secret token for API authentication (generate random 256-bit string)
ATLAS_TOKEN=change-me-to-random-256-bit-string
# Public version for client-side fetch (same value, exposes to browser)
NEXT_PUBLIC_ATLAS_TOKEN=change-me-to-random-256-bit-string

# Optional: OpenClaw gateway URL (default: http://localhost:3001)
# OPENCLAW_GATEWAY=http://localhost:3001

# Optional: Log level (debug, info, warn, error)
# LOG_LEVEL=info

# Optional: Database path (default: ./data/atlas.db)
# DATABASE_PATH=./data/atlas.db
