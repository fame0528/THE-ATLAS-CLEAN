# Atlas authentication token (required)
ATLAS_TOKEN=your-secure-random-token-here

# OpenClaw gateway URL (optional, default: http://localhost:3030)
# OPENCLAW_GATEWAY_URL=http://localhost:3030

# OpenClaw data directory (optional, default: C:\Users\spenc\.openclaw)
# OPENCLAW_DATA_DIR=C:\Users\spenc\.openclaw

# Database path (optional, default: atlas.db in project root)
# DATABASE_PATH=./atlas.db